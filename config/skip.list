# Packages to exclude from the dependency closure.
# Only includes packages that would genuinely cause issues if included.
#
# Criterion: Package could break Alpine, cause confusion, or is completely
# unusable (like games, bloated UIs, Debian-specific init systems).
#
# One Debian package name per line. Lines starting with # are ignored.

# Init system metadata (Alpine uses OpenRC, not systemd/sysvinit)
init-system-helpers         # Systemd/sysvinit integration (conflicts with Alpine init)
