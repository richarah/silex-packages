# Packages to exclude from the dependency closure.
# These are Debian-specific metadata with no value to users.
# Excluding them keeps the closure small and prevents unpredictable bloat.
#
# Criterion for inclusion: Package is useless to end users AND safe to exclude.
# Examples: Debian package metadata, system initialization files
# Non-examples: Core utilities, libraries, build tools (add to required-repo.list instead)
#
# One Debian package name per line. Lines starting with # are ignored.

# Debian-specific metadata (no user value)
base-files                  # Debian system file metadata
base-passwd                 # Debian users/groups metadata
debianutils                 # Debian-specific utilities (not useful in Alpine-based image)
perl-base                   # Perl core metadata

# Init system metadata (Alpine doesn't use systemd)
init-system-helpers         # Systemd/sysvinit initialization files
sysvinit-utils              # SysVinit initialization (Alpine uses Alpine init)
