# Packages to force-repack even if classify.sh detects .so files.
# Use for thin wrappers, transitional packages, or packages where
# compilation overhead exceeds any possible runtime benefit.
# One Debian package name per line. Lines starting with # are ignored.

# TBB: contains .so.2 but source build compiles 300+ test targets — no runtime
# benefit over the Debian binary for our use case (opencv build dep).
libtbb-dev
libtbb2
llvm-13-linker-tools
llvm-14-linker-tools
llvm-15-linker-tools
llvm-16-linker-tools
llvm-19-linker-tools
libxdmcp6
libxext6
libxfixes3
libxft2
libxi6
libxinerama1
libxkbcommon-x11-0
libxkbcommon0
libxrandr2
libxrender1
libxshmfence1
libxslt1.1
libxxf86vm1
libxtables12
libxxhash0
libyaml-0-2

# Force include packages that are missing from dependency chains
# but required by APK metadata
ncurses-bin
libz3-4
libzmq5
libclang-cpp13
libclang-cpp14
libclang-cpp15
libclang-cpp16
libclang-cpp19
libclang1-13
libclang1-14
libclang1-15
libclang1-16
libclang1-19
libllvm13
libllvm14
libllvm15
libllvm16
libllvm19
llvm-13-linker-tools
llvm-14-linker-tools
llvm-15-linker-tools
llvm-16-linker-tools
llvm-19-linker-tools

# Silex compat test packages (2026-03-28)
bison
flex
gfortran
libbz2-dev
libffi-dev
libncurses-dev
libpng-dev
libpcre3-dev
libreadline-dev
libtiff-dev
libtbb-dev
libssl-dev
pkg-config
python3-dev
curl
nginx
nodejs
npm
build-essential
tcl
libpcre3
zlib1g-dev

# GCC compiler toolchain - force repack instead of recompile
# Recompiling gcc requires gcc (bootstrap problem).
# Use Debian binary packages instead.
gcc
g++
gcc-11
gcc-12
gcc-13
gcc-13-x86-64-linux-gnu
gcc-14
gcc-14-x86-64-linux-gnu
gcc-15
gcc-15-x86-64-linux-gnu
g++-12
g++-13
g++-14
g++-15
