libxext6
libxfixes3
libxft2
libxi6
libxinerama1
libxkbcommon-x11-0
libxkbcommon0
libxrandr2
libxrender1
libxshmfence1
libxslt1.1
libxxf86vm1
libxtables12
libxxhash0
libyaml-0-2
libz3-4
libzmq5
