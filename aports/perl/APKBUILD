# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=perl
pkgver=5.40.0
pkgrel=0
pkgdesc="Practical Extraction and Report Language"
url="https://www.perl.org/"
arch="x86_64 aarch64"
license="Artistic-1.0-Perl OR GPL-1.0-or-later"
makedepends="zlib-dev bzip2-dev openssl-dev"
subpackages="$pkgname-dev"
provides="perl libperl-dev perl-base"
source="https://www.cpan.org/src/5.0/perl-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./Configure -des \
		-Dprefix=/usr \
		-Dvendorprefix=/usr \
		-Dprivlib=/usr/share/perl5/core_perl \
		-Darchlib=/usr/lib/perl5/core_perl \
		-Dsitelib=/usr/share/perl5/site_perl \
		-Dsitearch=/usr/lib/perl5/site_perl \
		-Dman1dir=/usr/share/man/man1 \
		-Dman3dir=/usr/share/man/man3 \
		-Duseshrplib \
		-Dusethreads \
		-Doptimize="$CFLAGS" \
		-Dccflags="$CFLAGS" \
		-Dldflags="$LDFLAGS" \
		-Dcc="$CC"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
	# Remove large pod documentation
	rm -rf "$pkgdir/usr/share/perl5/core_perl/pod"
}
