# Maintainer: silex-ci <ci@silex>
pkgname=curl
pkgver=8.12.1
pkgrel=0
pkgdesc="URL transfer tool and multi-protocol transfer library"
url="https://curl.se/"
arch="x86_64 aarch64"
license="curl"
makedepends="
	cmake
	ninja
	openssl-dev
	zlib-dev
	nghttp2-dev
	libssh2-dev
	c-ares-dev
	zstd-dev
	brotli-dev
	ca-certificates-bundle
	"
# libcurl: the shared library (runtime dep for programs that link -lcurl)
# curl-dev: headers, .pc, unversioned .so symlinks
# curl-static: libcurl.a
subpackages="libcurl:libs curl-dev:dev curl-static:static"
builddir="$srcdir/curl-$pkgver"
provides="libcurl4-openssl-dev libcurl4 curl libcurl-dev"
source="https://github.com/curl/curl/releases/download/curl-${pkgver//./_}/curl-$pkgver.tar.xz"
sha512sums="88915468fa1bb7256e3dd6c9d058ada6894faa1e3e7800c7d9bfee3e8be4081ae57e7f2bf260c5342b709499fc4302ddc2d7864e25bfa3300fa07f118a3de603  curl-8.12.1.tar.xz"
options="!check"

build() {
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DBUILD_STATIC_LIBS=ON \
		-DCURL_USE_OPENSSL=ON \
		-DCURL_USE_LIBSSH2=ON \
		-DUSE_NGHTTP2=ON \
		-DENABLE_ARES=ON \
		-DCURL_ZLIB=ON \
		-DCURL_ZSTD=ON \
		-DCURL_BROTLI=ON \
		-DBUILD_TESTING=OFF \
		-DBUILD_CURL_EXE=ON \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	# Installs everything: /usr/bin/curl, /usr/lib/libcurl.so*, libcurl.a,
	# /usr/include/curl/, /usr/lib/pkgconfig/libcurl.pc
	# Subpackage functions below split it up.
	DESTDIR="$pkgdir" ninja -C build install
}

libs() {
	pkgdesc="Multi-protocol transfer library"
	default_libs
}

static() {
	default_static
}
