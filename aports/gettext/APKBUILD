# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=gettext
pkgver=0.22.5
pkgrel=0
pkgdesc="GNU internationalization library and tools"
url="https://www.gnu.org/software/gettext/"
arch="x86_64 aarch64"
license="GPL-3.0-or-later AND LGPL-2.1-or-later"
makedepends="expat-dev ncurses-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libgettextpo-dev gettext-base"
source="https://ftp.gnu.org/gnu/gettext/gettext-$pkgver.tar.xz"
sha512sums="a60999bb9d09441f138214d87acb7e59aab81e765bb9253a77c54902681c5de164a5a04de2a9778dfb479dbdefaab2d5de1fbaf6095c555c43e7e9fd7a1c09bd  gettext-0.22.5.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--disable-java \
		--disable-native-java \
		--disable-csharp \
		--without-git \
		--without-cvs \
		--without-xz \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
