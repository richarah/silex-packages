# Maintainer: silex-ci <ci@silex>
pkgname=libtiff
pkgver=4.7.0
pkgrel=0
pkgdesc="TIFF library and tools"
url="https://libtiff.gitlab.io/libtiff/"
arch="x86_64 aarch64"
license="libtiff"
makedepends="cmake ninja zlib-dev libjpeg-turbo-dev xz-dev zstd-dev"
subpackages="$pkgname-dev $pkgname-static"
builddir="$srcdir/tiff-$pkgver"
provides="libtiff-dev libtiff6"
source="https://download.osgeo.org/libtiff/tiff-$pkgver.tar.gz"
sha512sums="a77a050d1d8777c6d86077c3c26e8d35f98717fe14bb3c049e2b82fbfbb374e96f83a0c1ff67ffb21591a9a7abf0d3e18c3d7695c96939326cc19a9712dd2492  tiff-4.7.0.tar.gz"
options="!check"

build() {
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_CXX_COMPILER="$CXX" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_CXX_FLAGS="$CXXFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-Dtiff-tests=OFF \
		-Dtiff-tools=ON \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
}

static() {
	default_static
}
