# Maintainer: silex-ci <ci@silex>
pkgname=jq
pkgver=1.7.1
pkgrel=0
pkgdesc="Lightweight and flexible command-line JSON processor"
url="https://jqlang.github.io/jq/"
arch="x86_64 aarch64"
license="MIT AND CC-BY-3.0"
makedepends="oniguruma-dev"
subpackages="$pkgname-dev"
source="https://github.com/jqlang/jq/releases/download/jq-$pkgver/jq-$pkgver.tar.gz"
sha512sums="464861fb2e0d6934b616f1dc7f8002d7dae727c8c0c07b385b813e7522ba1ada8ead4165e1d99c892e3ea76e238c55a15b718c738805419721920f88f8d8478c  jq-1.7.1.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--with-oniguruma \
		--disable-maintainer-mode \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
