# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=oniguruma
pkgver=6.9.9
pkgrel=0
pkgdesc="Regular expressions library"
url="https://github.com/kkos/oniguruma"
arch="x86_64 aarch64"
license="BSD-2-Clause"
makedepends=""
subpackages="$pkgname-dev $pkgname-static"
provides="libonig-dev libonig5"
source="https://github.com/kkos/oniguruma/releases/download/v$pkgver/onig-$pkgver.tar.gz"
sha512sums=""
builddir="$srcdir/onig-$pkgver"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
