# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libev
pkgver=4.33
pkgrel=0
pkgdesc="High-performance event loop library"
url="http://software.schmorp.de/pkg/libev.html"
arch="x86_64 aarch64"
license="BSD-2-Clause OR GPL-2.0-or-later"
makedepends=""
subpackages="$pkgname-dev"
provides="libev-dev libev4"
source="http://dist.schmorp.de/libev/Attic/libev-$pkgver.tar.bz2"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
