# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=opus
pkgver=1.5.2
pkgrel=0
pkgdesc="Totally open, royalty-free, highly versatile audio codec"
url="https://opus-codec.org/"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="cmake ninja"
subpackages="$pkgname-dev $pkgname-static"
provides="libopus-dev libopus0"
source="https://downloads.xiph.org/releases/opus/opus-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DOPUS_BUILD_PROGRAMS=OFF \
		-DOPUS_BUILD_TESTING=OFF
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
