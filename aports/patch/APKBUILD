# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=patch
pkgver=2.7.6
pkgrel=0
pkgdesc="GNU patch utility"
url="https://www.gnu.org/software/patch/"
arch="x86_64 aarch64"
license="GPL-3.0-or-later"
makedepends=""
provides="patch"
source="https://ftp.gnu.org/gnu/patch/patch-$pkgver.tar.xz"
sha512sums="fcca87bdb67a88685a8a25597f9e015f5e60197b9a269fa350ae35a7991ed8da553939b4bbc7f7d3cfd863c67142af403b04165633acbce4339056a905e87fbd  patch-2.7.6.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
