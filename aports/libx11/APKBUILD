# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libx11
pkgver=1.8.10
pkgrel=0
pkgdesc="X11 client-side library"
url="https://xorg.freedesktop.org/"
arch="x86_64 aarch64"
license="MIT"
makedepends="xorgproto libxcb-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libx11-dev libx11-6"
source="https://xorg.freedesktop.org/releases/individual/lib/libX11-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--disable-specs \
		--without-xmlto \
		--without-fop \
		--without-xsltproc \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
