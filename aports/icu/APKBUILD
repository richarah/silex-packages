# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=icu
pkgver=76.1
pkgrel=0
pkgdesc="International Components for Unicode"
url="https://icu.unicode.org/"
arch="x86_64 aarch64"
license="Unicode-3.0"
makedepends=""
subpackages="$pkgname-dev $pkgname-static"
provides="libicu-dev libicu72 libicu76"
source="https://github.com/unicode-org/icu/releases/download/release-76-1/icu4c-76_1-src.tgz"
sha512sums=""
builddir="$srcdir/icu/source"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--disable-static \
		--with-data-packaging=library \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
