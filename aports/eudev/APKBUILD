# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=eudev
pkgver=3.2.14
pkgrel=0
pkgdesc="Userspace device manager (udev fork)"
url="https://github.com/eudev-project/eudev"
arch="x86_64 aarch64"
license="GPL-2.0-or-later LGPL-2.1-or-later"
makedepends="linux-headers gperf"
subpackages="$pkgname-dev $pkgname-libs"
provides="udev libudev-dev libudev1"
source="https://github.com/eudev-project/eudev/releases/download/v$pkgver/eudev-$pkgver.tar.gz"
sha512sums="1e7593b53c5508a99fe7ff5d24d1d09b3753d9cfba086e7d8cc6ab80cc88013ec687dc4f1eac7b7889051f4e5fd5c40d2b87f5f2d948479d679c8836014d08e0  eudev-3.2.14.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--sbindir=/usr/sbin \
		--with-rootlibdir=/usr/lib \
		--enable-manpages=no \
		--disable-selinux \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

libs() {
	pkgdesc="$pkgdesc (shared library)"
	default_libs
}
