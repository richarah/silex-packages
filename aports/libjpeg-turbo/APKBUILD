# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libjpeg-turbo
pkgver=3.1.0
pkgrel=0
pkgdesc="SIMD-accelerated JPEG image codec"
url="https://libjpeg-turbo.org/"
arch="x86_64 aarch64"
license="BSD-3-Clause AND IJG AND Zlib"
makedepends="cmake ninja nasm"
subpackages="$pkgname-dev"
provides="libjpeg-dev libjpeg62-turbo-dev libjpeg62-turbo libjpeg-turbo-dev"
source="https://github.com/libjpeg-turbo/libjpeg-turbo/releases/download/$pkgver/libjpeg-turbo-$pkgver.tar.gz"
sha512sums="63231854529f59a95814cf2414fe384360a4ed96c572764fabc535c3770c559d26943e129c905a63d5949088fa79138b1ffdb175b817f2f4d36329a3cbb23ea7  libjpeg-turbo-3.1.0.tar.gz"
options="!check"

build() {
	cd "$builddir"
	cmake -B build -S . \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DENABLE_SHARED=ON \
		-DENABLE_STATIC=ON \
		-DWITH_JPEG8=ON \
		-DWITH_TURBOJPEG=ON \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	cd "$builddir"
	DESTDIR="$pkgdir" ninja -C build install
	# Create compatibility symlink
	ln -sf libjpeg.so "$pkgdir/usr/lib/libjpeg.so.8" 2>/dev/null || true
}

static() {
	default_static
}
