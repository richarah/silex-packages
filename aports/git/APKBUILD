# Maintainer: silex-ci <ci@silex>
pkgname=git
pkgver=2.47.2
pkgrel=0
pkgdesc="Distributed version control system"
url="https://git-scm.com/"
arch="x86_64 aarch64"
license="GPL-2.0-only"
makedepends="
	openssl-dev
	zlib-dev
	expat-dev
	pcre2-dev
	curl-dev
	perl
	"
provides="git git-core"
source="https://www.kernel.org/pub/software/scm/git/git-$pkgver.tar.xz"
sha512sums="a54aa6c8f468534311fa5e8fe9a69d0ea87b18a97f94b62e20882ab431e422975883852cbce03b14c99fd0a7a5b41d15307fdf4f147b601ce9d925b484831e07  git-2.47.2.tar.xz"
options="!check"

build() {
	cd "$builddir"
	make configure
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--with-openssl \
		--with-libpcre2 \
		--with-curl \
		--with-expat \
		--without-tcltk \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS INSTALLDIRS=vendor
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir" INSTALLDIRS=vendor
}
