# Maintainer: silex-ci <ci@silex>
pkgname=ncurses
pkgver=6.5
pkgrel=0
pkgdesc="Console terminal control library"
url="https://invisible-island.net/ncurses/"
arch="x86_64 aarch64"
license="MIT"
makedepends=""
subpackages="$pkgname-dev $pkgname-static $pkgname-terminfo-base:terminfo_base"
source="https://ftp.gnu.org/gnu/ncurses/ncurses-$pkgver.tar.gz"
sha512sums="fc5a13409d2a530a1325776dcce3a99127ddc2c03999cfeb0065d0eee2d68456274fb1c7b3cc99c1937bc657d0e7fca97016e147f93c7821b5a4a6837db821e8  ncurses-6.5.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--mandir=/usr/share/man \
		--with-shared \
		--with-normal \
		--with-cxx-shared \
		--without-debug \
		--enable-widec \
		--enable-pc-files \
		--with-pkg-config-libdir=/usr/lib/pkgconfig \
		--without-ada \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
	# Build non-wide variant (needed by some packages)
	mkdir -p buildnarrow
	cd buildnarrow
	../configure \
		--prefix=/usr \
		--with-shared \
		--with-normal \
		--without-debug \
		--without-ada \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
	# Compatibility symlinks (many packages link against -lncurses not -lncursesw)
	for lib in ncurses ncurses++ form panel menu; do
		ln -sf lib${lib}w.so "$pkgdir/usr/lib/lib${lib}.so" 2>/dev/null || true
		ln -sf lib${lib}w.a  "$pkgdir/usr/lib/lib${lib}.a"  2>/dev/null || true
	done
	# Compatibility headers
	ln -sf ncursesw "$pkgdir/usr/include/ncurses" 2>/dev/null || true
}

terminfo_base() {
	pkgdesc="Base terminfo files"
	mkdir -p "$subpkgdir/usr/share/terminfo"
	cp -a "$pkgdir/usr/share/terminfo/v" "$subpkgdir/usr/share/terminfo/" 2>/dev/null || true
	cp -a "$pkgdir/usr/share/terminfo/x" "$subpkgdir/usr/share/terminfo/" 2>/dev/null || true
	cp -a "$pkgdir/usr/share/terminfo/l" "$subpkgdir/usr/share/terminfo/" 2>/dev/null || true
}

static() {
	default_static
}
