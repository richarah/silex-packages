# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=bzip2
pkgver=1.0.8
pkgrel=0
pkgdesc="High-quality block-sorting file compressor"
url="https://sourceware.org/bzip2/"
arch="x86_64 aarch64"
license="bzip2-1.0.6"
makedepends=""
subpackages="$pkgname-dev $pkgname-static"
provides="libbz2-dev libbz2-1.0"
source="https://sourceware.org/pub/bzip2/bzip2-$pkgver.tar.gz"
sha512sums="083f5e675d73f3233c7930ebe20425a533feedeaaa9d8cc86831312a6581cefbe6ed0d08d2fa89be81082f2a5abdabca8b3c080bf97218a1bd59dc118a30b9f3  bzip2-1.0.8.tar.gz"

build() {
	cd "$builddir"
	# Shared library: strip -flto* flags — bzip2's two-step make (compile then
	# link the same .o files) is incompatible with ThinLTO, which leaves LLVM
	# bitcode in .o files that cannot be re-linked as a plain shared object.
	_cflags_nolto=$(printf '%s' "$CFLAGS" | sed 's/-flto[^ ]*//g')
	make -f Makefile-libbz2_so \
		CC="$CC" \
		CFLAGS="$_cflags_nolto -fPIC" \
		-j$JOBS
	# Static library and tools
	make \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS" \
		-j$JOBS
}

package() {
	cd "$builddir"
	make install PREFIX="$pkgdir/usr"
	# Install shared library (Makefile-libbz2_so does not install)
	install -Dm755 libbz2.so.$pkgver "$pkgdir/usr/lib/libbz2.so.$pkgver"
	ln -sf libbz2.so.$pkgver "$pkgdir/usr/lib/libbz2.so.1.0"
	ln -sf libbz2.so.$pkgver "$pkgdir/usr/lib/libbz2.so.1"
	ln -sf libbz2.so.$pkgver "$pkgdir/usr/lib/libbz2.so"
	# bzgrep, bzdiff, etc. are shell scripts — already installed by make install
}

static() {
	default_static
}
