# Maintainer: silex-ci <ci@silex>
pkgname=libargon2
pkgver=20190702
pkgrel=0
pkgdesc="Password hashing library implementing the Argon2 algorithm"
url="https://github.com/P-H-C/phc-winner-argon2"
arch="x86_64 aarch64"
license="Apache-2.0 OR CC0-1.0"
makedepends=""
subpackages="$pkgname-dev"
provides="libargon2-dev libargon2-1"
source="https://github.com/P-H-C/phc-winner-argon2/archive/refs/tags/$pkgver.tar.gz"
sha512sums=""
builddir="$srcdir/phc-winner-argon2-$pkgver"
options="!check"

build() {
	cd "$builddir"
	make -j$JOBS \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		OPTTARGET=none
}

package() {
	cd "$builddir"
	make install \
		PREFIX=/usr \
		DESTDIR="$pkgdir" \
		LIBRARY_REL=lib
}
