# Maintainer: Silex CI <noreply@richarah.github.io>
# Warning: GCC is a multi-hour build even on fast hardware.
# --disable-bootstrap builds in one pass with the host compiler (clang).
# This is correct: we are not building a self-hosting GCC, just a compiler.
pkgname=gcc
pkgver=14.2.0
pkgrel=0
pkgdesc="GNU Compiler Collection"
url="https://gcc.gnu.org/"
arch="x86_64 aarch64"
license="GPL-3.0-or-later AND LGPL-3.0-or-later"
makedepends="
	gmp-dev
	mpfr-dev
	mpc1-dev
	isl-dev
	zlib-dev
	linux-headers
	binutils
	"
# gfortran: Fortran frontend + libgfortran + libquadmath
# g++:      C++ frontend + libstdc++
subpackages="gfortran:fortran g++:cxx"
provides="gcc g++ gfortran cpp gcc-12 g++-12"
source="https://ftp.gnu.org/gnu/gcc/gcc-$pkgver/gcc-$pkgver.tar.xz"
sha512sums="932bdef0cda94bacedf452ab17f103c0cb511ff2cec55e9112fc0328cbf1d803b42595728ea7b200e0a057c03e85626f937012e49a7515bc5dd256b2bf4bc396  gcc-14.2.0.tar.xz"
options="!check"

# GCC must be built outside its source tree.
_gcc_builddir="$srcdir/gcc-build"

build() {
	# -flto=thin is a clang-specific flag. GCC itself does not support it as an
	# input to its own build. Strip it; -O3 and -march still apply.
	local _cflags="${CFLAGS//-flto=thin/}"
	local _ldflags="${LDFLAGS//-flto=thin/}"

	mkdir -p "$_gcc_builddir"
	cd "$_gcc_builddir"
	"$builddir/configure" \
		--prefix=/usr \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--libdir=/usr/lib \
		--libexecdir=/usr/lib \
		--enable-languages=c,c++,fortran \
		--enable-shared \
		--enable-threads=posix \
		--enable-__cxa_atexit \
		--disable-multilib \
		--disable-bootstrap \
		--disable-nls \
		--disable-werror \
		--enable-default-pie \
		--enable-default-ssp \
		--with-system-zlib \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$_cflags" \
		CXXFLAGS="$_cflags" \
		LDFLAGS="$_ldflags"
	make -j$JOBS
}

package() {
	cd "$_gcc_builddir"
	make install DESTDIR="$pkgdir"
	# Drop large documentation; man pages for the binaries are kept.
	rm -rf "$pkgdir/usr/share/info" "$pkgdir/usr/share/man/man7"
	# abuild-sign does not need the locale files
	rm -rf "$pkgdir/usr/share/locale"
}

fortran() {
	pkgdesc="GNU Fortran compiler"
	depends="gcc=$pkgver-r$pkgrel"
	mkdir -p "$subpkgdir/usr/bin" "$subpkgdir/usr/lib"

	# /usr/bin/gfortran and /usr/bin/gfortran-14
	mv "$pkgdir"/usr/bin/gfortran* "$subpkgdir/usr/bin/" 2>/dev/null || true

	# f951 (Fortran compiler proper) lives under usr/lib/gcc/<triplet>/<ver>/
	# Use a glob so we don't need to know the exact triplet.
	for _f951 in "$pkgdir"/usr/lib/gcc/*/*/f951; do
		_destdir="$subpkgdir/${_f951%/f951}"
		_destdir="${_destdir#$pkgdir/}"
		mkdir -p "$subpkgdir/$_destdir"
		mv "$_f951" "$subpkgdir/$_destdir/"
	done
	# finclude/ (Fortran module include dir)
	for _finc in "$pkgdir"/usr/lib/gcc/*/*/finclude; do
		_parent="${_finc%/finclude}"
		_rel="${_parent#$pkgdir/}"
		mv "$_finc" "$subpkgdir/$_rel/"
	done

	# Fortran runtime libraries
	mv "$pkgdir"/usr/lib/libgfortran*.so* "$subpkgdir/usr/lib/" 2>/dev/null || true
	mv "$pkgdir"/usr/lib/libgfortran*.a   "$subpkgdir/usr/lib/" 2>/dev/null || true
	mv "$pkgdir"/usr/lib/libquadmath*.so* "$subpkgdir/usr/lib/" 2>/dev/null || true
	mv "$pkgdir"/usr/lib/libquadmath*.a   "$subpkgdir/usr/lib/" 2>/dev/null || true
}

cxx() {
	pkgdesc="GNU C++ compiler"
	depends="gcc=$pkgver-r$pkgrel"
	mkdir -p "$subpkgdir/usr/bin" "$subpkgdir/usr/lib"

	mv "$pkgdir"/usr/bin/g++* "$subpkgdir/usr/bin/" 2>/dev/null || true
	mv "$pkgdir"/usr/bin/c++* "$subpkgdir/usr/bin/" 2>/dev/null || true

	# cc1plus (C++ compiler proper)
	for _cc1plus in "$pkgdir"/usr/lib/gcc/*/*/cc1plus; do
		_destdir="$subpkgdir/${_cc1plus%/cc1plus}"
		_destdir="${_destdir#$pkgdir/}"
		mkdir -p "$subpkgdir/$_destdir"
		mv "$_cc1plus" "$subpkgdir/$_destdir/"
	done

	mv "$pkgdir"/usr/lib/libstdc++*.so* "$subpkgdir/usr/lib/" 2>/dev/null || true
	mv "$pkgdir"/usr/lib/libstdc++*.a   "$subpkgdir/usr/lib/" 2>/dev/null || true
}
