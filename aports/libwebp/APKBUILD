# Maintainer: silex-ci <ci@silex>
pkgname=libwebp
pkgver=1.5.0
pkgrel=0
pkgdesc="WebP image format library"
url="https://chromium.googlesource.com/webm/libwebp"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="cmake ninja libpng-dev libjpeg-turbo-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libwebp-dev libwebp7"
source="https://storage.googleapis.com/downloads.webmproject.org/releases/webp/libwebp-$pkgver.tar.gz"
sha512sums="7a39594cf5585428f82d555b05e78aa63758a56841a313c0b74dfb4996afe37dddf92498d6123ff2a949a7209fb9097927f10ee75b5a38b481f110c892e5302b  libwebp-1.5.0.tar.gz"
options="!check"

build() {
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DWEBP_BUILD_ANIM_UTILS=OFF \
		-DWEBP_BUILD_CWEBP=ON \
		-DWEBP_BUILD_DWEBP=ON \
		-DWEBP_BUILD_GIF2WEBP=OFF \
		-DWEBP_BUILD_IMG2WEBP=OFF \
		-DWEBP_BUILD_VWEBP=OFF \
		-DWEBP_BUILD_WEBPINFO=ON \
		-DWEBP_BUILD_WEBPMUX=ON \
		-DWEBP_BUILD_EXTRAS=OFF \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
}

static() {
	default_static
}
