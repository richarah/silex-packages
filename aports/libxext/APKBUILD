# Maintainer: silex-ci <ci@silex>
pkgname=libxext
pkgver=1.3.6
pkgrel=0
pkgdesc="X11 miscellaneous extensions library"
url="https://xorg.freedesktop.org/"
arch="x86_64 aarch64"
license="MIT"
makedepends="xorgproto libx11-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libxext-dev libxext6"
source="https://xorg.freedesktop.org/releases/individual/lib/libXext-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
