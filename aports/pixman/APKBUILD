# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=pixman
pkgver=0.44.2
pkgrel=0
pkgdesc="Low-level pixel manipulation library"
url="https://pixman.org/"
arch="x86_64 aarch64"
license="MIT"
makedepends="meson ninja"
subpackages="$pkgname-dev"
provides="libpixman-1-dev libpixman-1-0"
source="https://www.cairographics.org/releases/pixman-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	meson setup build \
		--prefix=/usr \
		--buildtype=release \
		-Dtests=disabled \
		-Ddemos=disabled
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C "$builddir/build" install
}
