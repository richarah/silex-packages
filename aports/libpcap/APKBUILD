# Maintainer: silex-ci <ci@silex>
pkgname=libpcap
pkgver=1.10.5
pkgrel=0
pkgdesc="System-independent library for user-level network packet capture"
url="https://www.tcpdump.org/"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="linux-headers flex bison"
subpackages="$pkgname-dev $pkgname-static"
provides="libpcap-dev libpcap0.8 libpcap0.8-dev"
source="https://www.tcpdump.org/release/libpcap-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--disable-bluetooth \
		--disable-dbus \
		--disable-canusb \
		--disable-rdma \
		--without-libnl \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
