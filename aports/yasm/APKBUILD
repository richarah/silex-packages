# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=yasm
pkgver=1.3.0
pkgrel=0
pkgdesc="Modular assembler with support for multiple syntaxes"
url="https://yasm.tortall.net/"
arch="x86_64 aarch64"
license="BSD-2-Clause"
makedepends=""
provides=""
source="https://www.tortall.net/projects/yasm/releases/yasm-$pkgver.tar.gz"
sha512sums="572d3b45568b10f58e48f1188c2d6bcbdd16429c8afaccc8c6d37859b45635e106885d679e41d0bee78c23822108c7ae75aa7475eed5ba58057e0a6fe1b68645  yasm-1.3.0.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
