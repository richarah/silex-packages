# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=expat
pkgver=2.6.4
pkgrel=0
pkgdesc="XML parser library"
url="https://libexpat.github.io/"
arch="x86_64 aarch64"
license="MIT"
makedepends="cmake ninja"
subpackages="$pkgname-dev"
provides="libexpat1-dev libexpat1"
source="https://github.com/libexpat/libexpat/releases/download/R_${pkgver//./_}/expat-$pkgver.tar.xz"
sha512sums="620da34d98524478b445038bf1dd439790fe11169496516425fca922226797835c27549fc5fb825792b516563b24eb922d9ad8f27d20a0229e7ee8cd640dfb25  expat-2.6.4.tar.xz"
options="!check"

build() {
	cd "$builddir"
	cmake -B build -S . \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DEXPAT_BUILD_EXAMPLES=OFF \
		-DEXPAT_BUILD_TESTS=OFF \
		-DEXPAT_BUILD_DOCS=OFF \
		-DEXPAT_SHARED_LIBS=ON \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	cd "$builddir"
	DESTDIR="$pkgdir" ninja -C build install
}

static() {
	default_static
}
