# Maintainer: silex-ci <ci@silex>
pkgname=gmp
pkgver=6.3.0
pkgrel=0
pkgdesc="GNU Multiple Precision arithmetic library"
url="https://gmplib.org/"
arch="x86_64 aarch64"
license="LGPL-3.0-or-later OR GPL-2.0-or-later"
makedepends="m4"
subpackages="$pkgname-dev $pkgname-static"
provides="libgmp-dev libgmp10"
source="https://gmplib.org/download/gmp/gmp-$pkgver.tar.xz"
sha512sums="e85a0dab5195889948a3462189f0e0598d331d3457612e2d3350799dba2e244316d256f8161df5219538eb003e4b5343f989aaa00f96321559063ed8c8f29fd2  gmp-6.3.0.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--enable-static \
		--enable-cxx \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
