# Maintainer: silex-ci <ci@silex>
pkgname=file
pkgver=5.46
pkgrel=0
pkgdesc="Utility to determine file types"
url="https://www.darwinsys.com/file/"
arch="x86_64 aarch64"
license="BSD-2-Clause"
makedepends="zlib-dev"
subpackages="$pkgname-dev"
source="https://astron.com/pub/file/file-$pkgver.tar.gz"
sha512sums="a6cb7325c49fd4af159b7555bdd38149e48a5097207acbe5e36deb5b7493ad6ea94d703da6e0edece5bb32959581741f4213707e5cb0528cd46d75a97a5242dc  file-5.46.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
