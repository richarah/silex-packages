# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=openssl
pkgver=3.4.1
pkgrel=0
pkgdesc="Toolkit for TLS and general-purpose cryptography"
url="https://openssl.org/"
arch="x86_64 aarch64"
license="Apache-2.0"
makedepends="perl zlib-dev"
subpackages="$pkgname-dev $pkgname-static libssl3:ssl libcrypto3:crypto"
provides="libssl-dev libssl3 libcrypto-dev libssl-doc openssl-dev"
source="https://github.com/openssl/openssl/releases/download/openssl-$pkgver/openssl-$pkgver.tar.gz"
sha512sums="1de6307c587686711f05d1e96731c43526fa3af51e4cd94c06c880954b67f6eb4c7db3177f0ea5937d41bc1f8cadcf5bce75025b5c1a46a469376960f1001c5f  openssl-3.4.1.tar.gz"
options="!check"

build() {
	cd "$builddir"
	case "$CARCH" in
		x86_64)  _target=linux-x86_64 ;;
		aarch64) _target=linux-aarch64 ;;
		*)       _target=linux-generic64 ;;
	esac
	CC="$CC" CFLAGS="$CFLAGS" LDFLAGS="$LDFLAGS" \
	perl Configure "$_target" \
		--prefix=/usr \
		--openssldir=/etc/ssl \
		--libdir=lib \
		shared \
		zlib \
		no-async \
		enable-ec_nistp_64_gcc_128 \
		enable-ktls \
		-DOPENSSL_NO_DEPRECATED
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
	# Remove static libs from main package; they go to -static
	rm -f "$pkgdir/usr/lib/lib"*.a
}

ssl() {
	pkgdesc="SSL/TLS shared library"
	mkdir -p "$subpkgdir/usr/lib"
	mv "$pkgdir"/usr/lib/libssl.so* "$subpkgdir/usr/lib/"
}

crypto() {
	pkgdesc="OpenSSL cryptographic shared library"
	mkdir -p "$subpkgdir/usr/lib"
	mv "$pkgdir"/usr/lib/libcrypto.so* "$subpkgdir/usr/lib/"
}

static() {
	default_static
}
