# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=readline
pkgver=8.2
pkgrel=0
pkgdesc="GNU readline — consistent command line editing interface"
url="https://tiswww.case.edu/php/chet/readline/rltop.html"
arch="x86_64 aarch64"
license="GPL-3.0-or-later"
makedepends="ncurses-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libreadline-dev libreadline8"
source="https://ftp.gnu.org/gnu/readline/readline-$pkgver.tar.gz"
sha512sums="0a451d459146bfdeecc9cdd94bda6a6416d3e93abd80885a40b334312f16eb890f8618a27ca26868cebbddf1224983e631b1cbc002c1a4d1cd0d65fba9fea49a  readline-8.2.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--with-curses \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
