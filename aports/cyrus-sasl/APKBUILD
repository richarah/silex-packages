# Maintainer: silex-ci <ci@silex>
pkgname=cyrus-sasl
pkgver=2.1.28
pkgrel=0
pkgdesc="Cyrus SASL authentication library"
url="https://www.cyrusimap.org/sasl/"
arch="x86_64 aarch64"
license="BSD-4-Clause"
makedepends="openssl-dev"
subpackages="$pkgname-dev"
provides="libsasl2-dev libsasl2-2 sasl2-bin"
source="https://github.com/cyrusimap/cyrus-sasl/releases/download/cyrus-sasl-$pkgver/cyrus-sasl-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--with-plugindir=/usr/lib/sasl2 \
		--enable-shared \
		--disable-static \
		--with-openssl \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
