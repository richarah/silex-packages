# Maintainer: silex-ci <ci@silex>
pkgname=c-ares
pkgver=1.34.4
pkgrel=0
pkgdesc="C library for asynchronous DNS requests"
url="https://c-ares.org/"
arch="x86_64 aarch64"
license="MIT"
makedepends="cmake ninja"
subpackages="$pkgname-dev $pkgname-static"
provides="libc-ares-dev libc-ares2"
source="https://github.com/c-ares/c-ares/releases/download/v$pkgver/c-ares-$pkgver.tar.gz"
sha512sums="3285e14d94bc736d6caddfe7ad7e3c6a6e69d49b079c989bb3e8aba4da62c022e38229d1e691aaa030b7d3bcd89e458d203f260806149a71ad9adb31606eae02  c-ares-1.34.4.tar.gz"
options="!check"

build() {
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DCARES_SHARED=ON \
		-DCARES_STATIC=ON \
		-DCARES_BUILD_TESTS=OFF \
		-DCARES_BUILD_TOOLS=ON \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
}

static() {
	default_static
}
