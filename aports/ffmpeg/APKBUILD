# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=ffmpeg
pkgver=7.1
pkgrel=0
pkgdesc="Complete solution to record, convert and stream audio and video"
url="https://ffmpeg.org/"
arch="x86_64 aarch64"
license="GPL-2.0-or-later"
makedepends="zlib-dev xz-dev bzip2-dev openssl-dev nasm"
subpackages="$pkgname-dev $pkgname-libs:libs"
provides="libavcodec-dev libavformat-dev libswscale-dev libavutil-dev libswresample-dev libavfilter-dev"
source="https://ffmpeg.org/releases/ffmpeg-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--disable-static \
		--enable-gpl \
		--enable-version3 \
		--enable-openssl \
		--disable-debug \
		--disable-doc \
		--disable-ffplay \
		--enable-pic \
		--enable-avcodec \
		--enable-avformat \
		--enable-swscale \
		--enable-swresample \
		--enable-avfilter \
		--enable-network \
		--cc="$CC" \
		--cxx="$CXX" \
		--extra-cflags="$CFLAGS" \
		--extra-ldflags="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

libs() {
	pkgdesc="FFmpeg shared libraries"
	mkdir -p "$subpkgdir/usr/lib"
	mv "$pkgdir"/usr/lib/lib*.so* "$subpkgdir/usr/lib/"
}
