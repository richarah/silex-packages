# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=unzip
pkgver=6.0
pkgrel=0
pkgdesc="Info-ZIP decompression utility"
url="https://infozip.sourceforge.net/UnZip.html"
arch="x86_64 aarch64"
license="Info-ZIP"
makedepends="bzip2-dev"
# Version encoding: 6.0 -> unzip60
builddir="$srcdir/unzip60"
provides=""
source="https://downloads.sourceforge.net/infozip/unzip60.tar.gz"
sha512sums="0694e403ebc57b37218e00ec1a406cae5cc9c5b52b6798e0d4590840b6cdbf9ddc0d9471f67af783e960f8fa2e620394d51384257dca23d06bcd90224a80ce5d  unzip60.tar.gz"
options="!check"

build() {
	cd "$builddir"
	# Let the configure step auto-detect flags, then remove -DNO_DIR which
	# conflicts with -DHAVE_DIRENT_H on glibc (typedef redefinition in unix.c).
	make -f unix/Makefile flags CC="$CC" LF2="$LDFLAGS -lbz2"
	sed -i 's/ -DNO_DIR//g' flags
	make -f unix/Makefile generic \
		CC="$CC" \
		LF2="$LDFLAGS -lbz2"
}

package() {
	cd "$builddir"
	make -f unix/Makefile install \
		prefix="$pkgdir/usr"
}
