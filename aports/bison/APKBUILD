# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=bison
pkgver=3.8.2
pkgrel=0
pkgdesc="GNU general-purpose parser generator"
url="https://www.gnu.org/software/bison/"
arch="x86_64 aarch64"
license="GPL-3.0-or-later"
makedepends="m4 gettext-dev"
provides=""
source="https://ftp.gnu.org/gnu/bison/bison-$pkgver.tar.xz"
sha512sums="d4d23af6671406e97257892f90651b67f2ab95219831372be032190b7156c10a3435d457857e677445df8b2327aacccc15344acbbc3808a6f332a93cce23b444  bison-3.8.2.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
