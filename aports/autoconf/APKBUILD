# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=autoconf
pkgver=2.72
pkgrel=0
pkgdesc="Tool for generating portable configure scripts"
url="https://www.gnu.org/software/autoconf/"
arch="x86_64 aarch64"
license="GPL-3.0-or-later"
makedepends="m4 perl"
provides="autoconf"
source="https://ftp.gnu.org/gnu/autoconf/autoconf-$pkgver.tar.xz"
sha512sums="c4e9fbd858666d3e5c3b4fe7f89aa3e8e3a0a00dc7e166f8147d937d911b77ba3ac6a016f9d223ccdd830bc8960b3e60397c0607cc6a1fd2c50c7492839ddd17  autoconf-2.72.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
