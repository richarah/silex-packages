# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=alsa-lib
pkgver=1.2.13
pkgrel=0
pkgdesc="ALSA sound library"
url="https://www.alsa-project.org/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later"
makedepends="linux-headers"
subpackages="$pkgname-dev $pkgname-static"
provides="libasound2-dev libasound2"
source="https://www.alsa-project.org/files/pub/lib/alsa-lib-$pkgver.tar.bz2"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--libdir=/usr/lib \
		--with-plugindir=/usr/lib/alsa-lib \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
