# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=openldap
pkgver=2.6.9
pkgrel=0
pkgdesc="OpenLDAP client libraries and utilities"
url="https://www.openldap.org/"
arch="x86_64 aarch64"
license="OLDAP-2.8"
makedepends="openssl-dev cyrus-sasl-dev"
subpackages="$pkgname-dev"
provides="libldap2-dev libldap-2.5-0 ldap-utils"
source="https://www.openldap.org/software/download/OpenLDAP/openldap-release/openldap-$pkgver.tgz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--libexecdir=/usr/lib \
		--localstatedir=/var/lib/openldap \
		--disable-slapd \
		--enable-shared \
		--with-tls=openssl \
		--with-cyrus-sasl \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
