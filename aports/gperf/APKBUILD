# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=gperf
pkgver=3.1
pkgrel=0
pkgdesc="Perfect hash function generator"
url="https://www.gnu.org/software/gperf/"
arch="x86_64 aarch64"
license="GPL-3.0-or-later"
makedepends=""
provides=""
source="https://ftp.gnu.org/gnu/gperf/gperf-$pkgver.tar.gz"
sha512sums="855ebce5ff36753238a44f14c95be7afdc3990b085960345ca2caf1a2db884f7db74d406ce9eec2f4a52abb8a063d4ed000a36b317c9a353ef4e25e2cca9a3f4  gperf-3.1.tar.gz"
options="!check"

build() {
	cd "$builddir"
	# gperf 3.1 uses 'register' in getline.cc; removed in C++17.
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS -std=c++14" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
