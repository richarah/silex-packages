# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libedit
pkgver=20240808-3.1
pkgrel=0
pkgdesc="BSD line editing library (readline alternative)"
url="https://www.thrysoee.dk/editline/"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="ncurses-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libedit-dev libedit2"
source="https://www.thrysoee.dk/editline/libedit-$pkgver.tar.gz"
sha512sums="b11d64947f9484bb2320b0fbcfdc94466993af1dfa0d853853b73c222e95d6c1e78d88d0c305929b95bf7a85009129475c9fef0ac8595b43d75543d85052a4ff  libedit-20240808-3.1.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
