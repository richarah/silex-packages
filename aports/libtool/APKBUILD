# Maintainer: silex-ci <ci@silex>
pkgname=libtool
pkgver=2.4.7
pkgrel=0
pkgdesc="Generic shared library generation tool"
url="https://www.gnu.org/software/libtool/"
arch="x86_64 aarch64"
license="GPL-2.0-or-later"
makedepends="autoconf automake m4"
provides="libtool libltdl-dev"
source="https://ftp.gnu.org/gnu/libtool/libtool-$pkgver.tar.xz"
sha512sums="47f4c6de40927254ff9ba452612c0702aea6f4edc7e797f0966c8c6bf0340d533598976cdba17f0bdc64545572e71cd319bbb587aa5f47cd2e7c1d96f873a3da  libtool-2.4.7.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
