# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=cairo
pkgver=1.18.2
pkgrel=0
pkgdesc="Multi-platform 2D graphics library"
url="https://www.cairographics.org/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later OR MPL-1.1"
makedepends="meson ninja pixman-dev freetype-dev fontconfig-dev libpng-dev zlib-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libcairo2-dev libcairo2 libcairo-gobject2"
source="https://www.cairographics.org/releases/cairo-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	meson setup build \
		--prefix=/usr \
		--buildtype=release \
		-Dtests=disabled \
		-Dspectre=disabled \
		-Dgl-backend=disabled \
		-Dglesv2=disabled \
		-Dxlib=disabled \
		-Dxcb=disabled
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C "$builddir/build" install
}
