# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=zlib
pkgver=1.3.2
pkgrel=0
pkgdesc="Compression library implementing the deflate algorithm"
url="https://zlib.net"
arch="x86_64 aarch64"
license="Zlib"
makedepends=""
subpackages="$pkgname-dev $pkgname-static"
provides="zlib1g zlib1g-dev"
source="https://github.com/madler/zlib/releases/download/v$pkgver/zlib-$pkgver.tar.gz"
sha512sums="70963771ea5d763614278a69b474f09b7d237ef8f53b675a10fe31d9923aeef601504b35d7ebd1b1e7f347e9ebb048e6b3b47fffdf137e7bdc7e8d5eb4ec4692  zlib-1.3.2.tar.gz"

build() {
	printf 'APKBUILD CC=[%s]\n' "$CC" >&2
	printf 'APKBUILD CFLAGS=[%s]\n' "$CFLAGS" >&2
	echo 'int foo() { return 0; }' > /tmp/_diagtest.c
	_diag=$("$CC" -c $CFLAGS /tmp/_diagtest.c 2>&1); _ret=$?
	printf 'compile-test: exit=%d output=[%s]\n' "$_ret" "$_diag" >&2
	cd "$builddir"
	CFLAGS="$CFLAGS" LDFLAGS="$LDFLAGS" \
		./configure \
		--prefix=/usr \
		--shared
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
