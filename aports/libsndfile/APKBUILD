# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libsndfile
pkgver=1.2.2
pkgrel=0
pkgdesc="Library for reading and writing audio files"
url="https://libsndfile.github.io/libsndfile/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later"
makedepends="cmake ninja"
subpackages="$pkgname-dev"
provides="libsndfile1-dev libsndfile1"
source="https://github.com/libsndfile/libsndfile/releases/download/$pkgver/libsndfile-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DBUILD_PROGRAMS=OFF \
		-DBUILD_EXAMPLES=OFF \
		-DBUILD_TESTING=OFF
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
