# Maintainer: silex-ci <ci@silex>
pkgname=gnutls
pkgver=3.8.8
pkgrel=0
pkgdesc="TLS/SSL and DTLS implementation library"
url="https://www.gnutls.org/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later"
makedepends="
	gmp-dev
	nettle-dev
	libtasn1-dev
	p11-kit-dev
	libffi-dev
	libidn2-dev
	zlib-dev
	gettext-dev
	"
subpackages="$pkgname-dev $pkgname-static"
provides="libgnutls28-dev libgnutls30"
source="https://www.gnupg.org/ftp/gcrypt/gnutls/v${pkgver%.*}/gnutls-$pkgver.tar.xz"
sha512sums="4f617c63e8e8392e400d72c9e39989fcd782268b4a4c4e36bbfb0444a4b5bcb0f53054f04a6dce99ab89c0f38f57430c95aaaec6eb9209b8e9329140abf230c3  gnutls-3.8.8.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--enable-shared \
		--disable-static \
		--disable-doc \
		--disable-full-test-suite \
		--with-default-trust-store-pkcs11="" \
		--with-default-trust-store-file=/etc/ssl/certs/ca-certificates.crt \
		--without-tpm \
		--without-tpm2 \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
