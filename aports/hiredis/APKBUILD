# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=hiredis
pkgver=1.2.0
pkgrel=0
pkgdesc="Minimalistic C client for Redis"
url="https://github.com/redis/hiredis"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="cmake ninja openssl-dev"
subpackages="$pkgname-dev"
provides="libhiredis-dev libhiredis0.14"
source="https://github.com/redis/hiredis/archive/refs/tags/v$pkgver.tar.gz"
sha512sums=""
builddir="$srcdir/hiredis-$pkgver"
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DENABLE_SSL=ON
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
