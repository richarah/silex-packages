# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=flex
pkgver=2.6.4
pkgrel=0
pkgdesc="Fast lexical analyser generator"
url="https://github.com/westes/flex"
arch="x86_64 aarch64"
license="BSD-2-Clause"
makedepends="m4"
subpackages="$pkgname-dev $pkgname-static"
provides="flex libfl-dev"
source="https://github.com/westes/flex/releases/download/v$pkgver/flex-$pkgver.tar.gz"
sha512sums="e9785f3d620a204b7d20222888917dc065c2036cae28667065bf7862dfa1b25235095a12fd04efdbd09bfd17d3452e6b9ef953a8c1137862ff671c97132a082e  flex-2.6.4.tar.gz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--disable-nls \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

static() {
	default_static
}
