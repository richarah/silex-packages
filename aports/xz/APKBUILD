# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=xz
pkgver=5.6.3
pkgrel=0
pkgdesc="Library and tools for XZ/LZMA compression"
url="https://tukaani.org/xz/"
arch="x86_64 aarch64"
license="0BSD AND LGPL-2.1-or-later AND GPL-2.0-or-later"
makedepends=""
subpackages="$pkgname-dev $pkgname-libs"
provides="liblzma-dev liblzma5 xz-utils"
source="https://github.com/tukaani-project/xz/releases/download/v$pkgver/xz-$pkgver.tar.xz"
sha512sums="1449f3b55819fb7f46855e550e367e96d658f523531fc2a65c2e1f1b847de86bf2fa50f3909f42cbff94a56b0cf8b0b5cd278097622da980119548f61e245f0a  xz-5.6.3.tar.xz"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--enable-static \
		--disable-rpath \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

libs() {
	pkgdesc="$pkgdesc (shared library)"
	default_libs
}

static() {
	default_static
}
