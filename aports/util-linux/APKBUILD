# Maintainer: silex-ci <ci@silex>
pkgname=util-linux
pkgver=2.40.2
pkgrel=0
pkgdesc="Random collection of Linux utilities"
url="https://www.kernel.org/pub/linux/utils/util-linux/"
arch="x86_64 aarch64"
license="GPL-2.0-or-later AND LGPL-2.1-or-later"
makedepends="
	meson
	ninja
	zlib-dev
	linux-headers
	ncurses-dev
	"
subpackages="
	$pkgname-dev
	libuuid:uuid
	libblkid:blkid
	libmount:mount
	"
source="https://www.kernel.org/pub/linux/utils/util-linux/v${pkgver%.*}/util-linux-$pkgver.tar.xz"
sha512sums="ffe20b915a518a150401d429b0338bc7022190e4ca0ef91a6d9eea345db8c1e11ad01784163b8fcf978506f3f5cad473f29d5d4ef93a4c66a5ae0ebd9fb0c8f2  util-linux-2.40.2.tar.xz"
options="!check"

build() {
	meson setup build "$builddir" \
		--prefix=/usr \
		--sysconfdir=/etc \
		--localstatedir=/var \
		--buildtype=release \
		-Dtinfo=disabled \
		-Dbuild-python=disabled \
		-Dsystemd=disabled \
		-Dudev=disabled \
		-Dselinux=disabled \
		-Daudit=disabled \
		-Dncurses=enabled \
		-Dzlib=enabled \
		-Dbuild-fdisk=enabled \
		-Dbuild-mount=enabled \
		-Dbuild-libblkid=enabled \
		-Dbuild-libmount=enabled \
		-Dbuild-libuuid=enabled \
		-Dbuild-libsmartcols=enabled
	meson compile -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" meson install -C build
}

uuid() {
	pkgdesc="UUID library from util-linux"
	mkdir -p "$subpkgdir/usr/lib"
	mv "$pkgdir"/usr/lib/libuuid.so* "$subpkgdir/usr/lib/"
}

blkid() {
	pkgdesc="Block device id library from util-linux"
	mkdir -p "$subpkgdir/usr/lib"
	mv "$pkgdir"/usr/lib/libblkid.so* "$subpkgdir/usr/lib/"
}

mount() {
	pkgdesc="Mount library from util-linux"
	mkdir -p "$subpkgdir/usr/lib"
	mv "$pkgdir"/usr/lib/libmount.so* "$subpkgdir/usr/lib/"
}
