# Maintainer: silex-ci <ci@silex>
pkgname=automake
pkgver=1.17
pkgrel=0
pkgdesc="Tool for automatically generating Makefile.in files"
url="https://www.gnu.org/software/automake/"
arch="x86_64 aarch64"
license="GPL-2.0-or-later"
makedepends="autoconf perl"
provides="automake"
source="https://ftp.gnu.org/gnu/automake/automake-$pkgver.tar.xz"
sha512sums="46aba1c9d64a6368b326020803a2999831c1deaf31eaa1c1dfdcfa5138a7f755643294e82a08b6daab3983b31eee725bdb7b9edc4e9a558374c7d1f1b8e854a7  automake-1.17.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
