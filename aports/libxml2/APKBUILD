# Maintainer: silex-ci <ci@silex>
pkgname=libxml2
pkgver=2.13.5
pkgrel=0
pkgdesc="XML parsing library"
url="https://gitlab.gnome.org/GNOME/libxml2"
arch="x86_64 aarch64"
license="MIT"
makedepends="cmake ninja zlib-dev xz-dev"
subpackages="$pkgname-dev $pkgname-static"
source="https://download.gnome.org/sources/libxml2/${pkgver%.*}/libxml2-$pkgver.tar.xz"
sha512sums="acaecd4e3e95136d1c621f9e5f33976ebca87dfbf83859459e339597c3c57fbc47508a7de16af7fbf0e7e7c59fd6f9a82b2e732e1dd12efd79d666bac64ecf4e  libxml2-2.13.5.tar.xz"
options="!check"

build() {
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DLIBXML2_WITH_ZLIB=ON \
		-DLIBXML2_WITH_LZMA=ON \
		-DLIBXML2_WITH_PYTHON=OFF \
		-DLIBXML2_WITH_TESTS=OFF \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
}

static() {
	default_static
}
