# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libmicrohttpd
pkgver=1.0.1
pkgrel=0
pkgdesc="Small C library for embedding HTTP server functionality"
url="https://www.gnu.org/software/libmicrohttpd/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later"
makedepends="openssl-dev"
subpackages="$pkgname-dev"
provides="libmicrohttpd-dev libmicrohttpd12"
source="https://ftp.gnu.org/gnu/libmicrohttpd/libmicrohttpd-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--disable-static \
		--with-openssl \
		--disable-doc \
		--disable-examples \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
