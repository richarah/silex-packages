# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libcap
pkgver=2.73
pkgrel=0
pkgdesc="POSIX 1003.1e capabilities library"
url="https://sites.google.com/site/fullycapable/"
arch="x86_64 aarch64"
license="BSD-3-Clause OR GPL-2.0-only"
makedepends="linux-headers perl"
subpackages="$pkgname-dev"
provides="libcap-dev libcap2"
source="https://www.kernel.org/pub/linux/libs/security/linux-privs/libcap2/libcap-$pkgver.tar.xz"
sha512sums="8ab72cf39bf029656b2a4a5972a0da4ab4b46a3d8a8da66d6cde925e06fe34df2fa5fc4d0b62c9cec4972b0b2678fdac6ef9421b6fb83c2a5bf869cf8d5fdb16  libcap-2.73.tar.xz"
options="!check"

build() {
	cd "$builddir"
	make \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS" \
		lib=lib \
		PAM_CAP=no \
		-j$JOBS
}

package() {
	cd "$builddir"
	make install \
		DESTDIR="$pkgdir" \
		lib=lib \
		PAM_CAP=no \
		RAISE_SETFCAP=no
}

static() {
	default_static
}
