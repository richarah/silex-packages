# Maintainer: silex-ci <ci@silex>
pkgname=boost
pkgver=1.87.0
pkgrel=0
pkgdesc="Free peer-reviewed portable C++ source libraries"
url="https://www.boost.org/"
arch="x86_64 aarch64"
license="BSL-1.0"
makedepends="cmake ninja python3 bzip2-dev zlib-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libboost-all-dev libboost-dev libboost-system-dev libboost-filesystem-dev libboost-thread-dev libboost-regex-dev libboost-program-options-dev libboost-date-time-dev libboost-iostreams-dev"
source="https://github.com/boostorg/boost/releases/download/boost-$pkgver/boost-$pkgver-cmake.tar.xz"
sha512sums=""
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_CXX_COMPILER="$CXX" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_CXX_FLAGS="$CXXFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DBOOST_INSTALL_LAYOUT=system \
		-DBOOST_ENABLE_PYTHON=OFF
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
