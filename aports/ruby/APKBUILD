# Maintainer: silex-ci <ci@silex>
pkgname=ruby
pkgver=3.4.2
pkgrel=0
pkgdesc="Dynamic, interpreted, open source programming language"
url="https://www.ruby-lang.org/"
arch="x86_64 aarch64"
license="Ruby OR BSD-2-Clause"
makedepends="zlib-dev openssl-dev readline-dev libffi-dev gmp-dev ncurses-dev"
subpackages="$pkgname-dev"
provides="ruby ruby-dev ruby-full"
source="https://cache.ruby-lang.org/pub/ruby/3.4/ruby-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--disable-install-doc \
		--with-openssl-dir=/usr \
		CC="$CC" \
		CXX="$CXX" \
		CFLAGS="$CFLAGS" \
		CXXFLAGS="$CXXFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
