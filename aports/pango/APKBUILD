# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=pango
pkgver=1.55.0
pkgrel=0
pkgdesc="Library for layout and rendering of internationalized text"
url="https://pango.gnome.org/"
arch="x86_64 aarch64"
license="LGPL-2.0-or-later"
makedepends="meson ninja harfbuzz-dev fontconfig-dev cairo-dev freetype-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libpango1.0-dev libpango-1.0-0 libpangocairo-1.0-0 libpangoft2-1.0-0"
source="https://download.gnome.org/sources/pango/1.55/pango-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	meson setup build \
		--prefix=/usr \
		--buildtype=release \
		-Dintrospection=disabled \
		-Dgtk_doc=false
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C "$builddir/build" install
}
