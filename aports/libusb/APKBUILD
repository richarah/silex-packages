# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libusb
pkgver=1.0.27
pkgrel=0
pkgdesc="Library for USB device access"
url="https://libusb.info/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later"
makedepends="linux-headers"
subpackages="$pkgname-dev"
provides="libusb-1.0-0-dev libusb-1.0-0"
source="https://github.com/libusb/libusb/releases/download/v$pkgver/libusb-$pkgver.tar.bz2"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--disable-udev \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
