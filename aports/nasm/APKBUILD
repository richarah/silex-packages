# Maintainer: silex-ci <ci@silex>
pkgname=nasm
pkgver=2.16.03
pkgrel=0
pkgdesc="Netwide Assembler — portable x86/x86-64 assembler"
url="https://www.nasm.us/"
arch="x86_64 aarch64"
license="BSD-2-Clause"
makedepends=""
provides="nasm"
source="https://www.nasm.us/pub/nasm/releasebuilds/$pkgver/nasm-$pkgver.tar.xz"
sha512sums="0c706e41a9c33e1ac3bad5056e8bf8cbcd51785b551a6e34ce7d0d723df8eaab8603a033e89b3dcda1004b558f9e9ef3196691500f10d8201bf47a323a516f84  nasm-2.16.03.tar.xz"
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
