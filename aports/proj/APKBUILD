# Maintainer: silex-ci <ci@silex>
pkgname=proj
pkgver=9.5.1
pkgrel=0
pkgdesc="Cartographic Projections and Coordinate Transformations Library"
url="https://proj.org/"
arch="x86_64 aarch64"
license="MIT"
makedepends="cmake ninja sqlite-dev curl-dev tiff-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libproj-dev libproj25"
source="https://download.osgeo.org/proj/proj-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_CXX_COMPILER="$CXX" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_CXX_FLAGS="$CXXFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DBUILD_TESTING=OFF
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
