# Maintainer: silex-ci <ci@silex>
# Provides libmysqlclient-compatible ABI for Dockerfile apt-get installs of
# libmysqlclient-dev / default-libmysqlclient-dev.
pkgname=mariadb-connector-c
pkgver=3.4.1
pkgrel=0
pkgdesc="MariaDB/MySQL client library (libmariadb / libmysqlclient)"
url="https://mariadb.com/kb/en/mariadb-connector-c/"
arch="x86_64 aarch64"
license="LGPL-2.1-or-later"
makedepends="cmake ninja openssl-dev zlib-dev"
subpackages="$pkgname-dev"
source="mariadb-connector-c-$pkgver-src.tar.gz::https://github.com/mariadb-corporation/mariadb-connector-c/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/mariadb-connector-c-$pkgver"
sha512sums="396ce2a36937d49ec96eb239312118c736f46383d2906b7142d9695e795f310af28255d8827cc98ad76ae4e6d5a22faf1188b7dd286791e3c85f22c96d0114b3  mariadb-connector-c-3.4.1-src.tar.gz"
options="!check"

build() {
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DWITH_OPENSSL=ON \
		-DWITH_ZLIB=ON \
		-DWITH_UNIT_TESTS=OFF \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
	# Compatibility symlink expected by programs linking -lmysqlclient
	ln -sf libmariadb.so "$pkgdir/usr/lib/libmysqlclient.so" 2>/dev/null || true
}
