# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=nettle
pkgver=3.10.1
pkgrel=0
pkgdesc="Low-level cryptographic library"
url="https://www.lysator.liu.se/~nisse/nettle/"
arch="x86_64 aarch64"
license="LGPL-3.0-or-later OR GPL-2.0-or-later"
makedepends="gmp-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="nettle-dev libnettle8 libhogweed6"
source="https://ftp.gnu.org/gnu/nettle/nettle-$pkgver.tar.gz"
sha512sums=""
options="!check"

build() {
	cd "$builddir"
	./configure \
		--prefix=/usr \
		--enable-shared \
		--disable-static \
		CC="$CC" \
		CFLAGS="$CFLAGS" \
		LDFLAGS="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}
