# Maintainer: silex-ci <ci@silex>
pkgname=snappy
pkgver=1.2.1
pkgrel=0
pkgdesc="Fast compressor/decompressor library"
url="https://google.github.io/snappy/"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="cmake ninja"
subpackages="$pkgname-dev $pkgname-static"
provides="libsnappy-dev libsnappy1v5"
source="https://github.com/google/snappy/archive/refs/tags/$pkgver.tar.gz"
sha512sums=""
builddir="$srcdir/snappy-$pkgver"
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_CXX_COMPILER="$CXX" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_CXX_FLAGS="$CXXFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON \
		-DSNAPPY_BUILD_TESTS=OFF \
		-DSNAPPY_BUILD_BENCHMARKS=OFF
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
