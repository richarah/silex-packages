# Maintainer: silex-ci <ci@silex>
# Warning: Node.js builds take 30-60 minutes even on fast hardware.
# Node bundles V8, libuv, and most deps internally.
# We link against system openssl and zlib to reduce binary size.
pkgname=nodejs
pkgver=22.13.1
pkgrel=0
pkgdesc="JavaScript runtime built on V8 (LTS)"
url="https://nodejs.org/"
arch="x86_64 aarch64"
license="MIT"
makedepends="
	openssl-dev
	zlib-dev
	c-ares-dev
	nghttp2-dev
	python3
	"
subpackages="npm:_npm"
builddir="$srcdir/node-v$pkgver"
source="https://nodejs.org/dist/v$pkgver/node-v$pkgver.tar.gz"
sha512sums="d4b9c4203ea7b77be98143d733c593267764d450bd70a60e5a621a8914015195cab48c329623d8e8cb05b79046fb548181c768005135f49843ee9e507d526659  node-v22.13.1.tar.gz"
options="!check"

build() {
	cd "$builddir"
	# Node's configure is a Python script wrapping GN.
	python3 configure.py \
		--prefix=/usr \
		--shared-openssl \
		--shared-zlib \
		--with-intl=none \
		--without-dtrace \
		--without-etw \
		--openssl-use-def-ca-store \
		--release-urlbase=https://nodejs.org/download/release/ \
		--cc="$CC" \
		--cxx="$CXX" \
		--extra-cflags="$CFLAGS" \
		--extra-cxxflags="$CXXFLAGS" \
		--extra-ldflags="$LDFLAGS"
	make -j$JOBS
}

package() {
	cd "$builddir"
	make install DESTDIR="$pkgdir"
}

_npm() {
	pkgdesc="Node.js package manager"
	depends="nodejs"
	mkdir -p "$subpkgdir/usr"
	# npm ships inside node's tree; move it out
	mv "$pkgdir/usr/lib/node_modules" "$subpkgdir/usr/lib/" 2>/dev/null || true
	mv "$pkgdir/usr/bin/npm" "$subpkgdir/usr/bin/" 2>/dev/null || true
	mv "$pkgdir/usr/bin/npx" "$subpkgdir/usr/bin/" 2>/dev/null || true
}
