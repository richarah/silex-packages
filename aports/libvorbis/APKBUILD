# Maintainer: Silex CI <noreply@richarah.github.io>
pkgname=libvorbis
pkgver=1.3.7
pkgrel=0
pkgdesc="Ogg Vorbis audio codec library"
url="https://xiph.org/vorbis/"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="cmake ninja libogg-dev"
subpackages="$pkgname-dev $pkgname-static"
provides="libvorbis-dev libvorbis0a libvorbisenc2 libvorbisfile3"
source="https://downloads.xiph.org/releases/vorbis/libvorbis-$pkgver.tar.xz"
sha512sums=""
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DBUILD_SHARED_LIBS=ON
	cmake --build build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
