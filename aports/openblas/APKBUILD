# Maintainer: silex-ci <ci@silex>
pkgname=openblas
pkgver=0.3.28
pkgrel=0
pkgdesc="Optimized BLAS and LAPACK library"
url="https://www.openblas.net/"
arch="x86_64 aarch64"
license="BSD-3-Clause"
makedepends="cmake ninja gfortran"
subpackages="$pkgname-dev $pkgname-static"
source="https://github.com/OpenMathLib/OpenBLAS/releases/download/v$pkgver/OpenBLAS-$pkgver.tar.gz"
builddir="$srcdir/OpenBLAS-$pkgver"
sha512sums="358301c8a60bedf920c07a110c772feb639e52412bd783789741fd2fd0686aac97e6b17ebcdf01ce48a2a15841058f82df0fee551af952f6e70b58140c055133  OpenBLAS-0.3.28.tar.gz"
options="!check"

build() {
	# TARGET: HASWELL covers x86-64-v3 (AVX2, FMA3).
	# For aarch64 we use ARMV8.
	case "$CARCH" in
		x86_64)  _target=HASWELL ;;
		aarch64) _target=ARMV8 ;;
	esac
	cmake -B build -S "$builddir" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_C_COMPILER="$CC" \
		-DCMAKE_Fortran_COMPILER=gfortran \
		-DCMAKE_C_FLAGS="$CFLAGS" \
		-DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS" \
		-DCMAKE_SHARED_LINKER_FLAGS="$LDFLAGS" \
		-DTARGET="$_target" \
		-DBINARY=64 \
		-DNUM_THREADS=64 \
		-DBUILD_SHARED_LIBS=ON \
		-DBUILD_STATIC_LIBS=ON \
		-DBUILD_TESTING=OFF \
		-G Ninja
	ninja -C build -j$JOBS
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
}

static() {
	default_static
}
