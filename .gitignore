*.rsa


# Built packages (CI commits these, don't track locally)
x86_64/*.apk
aarch64/*.apk
x86_64/APKINDEX.tar.gz
aarch64/APKINDEX.tar.gz

# abuild working directories
*/src/
*/pkg/
tmp/

# Private key (NEVER commit)
*.rsa
!*.rsa.pub

# abuild config with key path
/root/.abuild/

# Source tarballs (downloaded during build)
*.tar.gz
*.tar.xz
*.tar.bz2

