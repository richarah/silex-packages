# Signing keys — track public, never private
keys/*.rsa
!keys/*.rsa.pub
*.rsa
!*.rsa.pub

# Built packages — CI commits these, do not track locally
x86_64/*.apk
aarch64/*.apk
x86_64/APKINDEX.tar.gz
aarch64/APKINDEX.tar.gz

# abuild working directories
*/src/
*/pkg/
tmp/

# Source tarballs downloaded during build
*.tar.gz
*.tar.xz
*.tar.bz2
*.tgz

# OS junk
.DS_Store
Thumbs.db
